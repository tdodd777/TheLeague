# Sleeper league ID. Everything else (league name, dynasty flag, manager identities,
# scoring rules, FantasyCalc params) is auto-detected from the Sleeper API.
SLEEPER_LEAGUE_ID=

# Optional: set on the host (Netlify env vars) so OG image URLs resolve in
# production. Netlify exposes a built-in `URL` env var that the layout uses
# as a fallback. Not needed locally.
# SITE_URL=https://your-site.netlify.app

# NOTE: `NETLIFY_BUILD_HOOK_URL` is not an application env var — it's a GitHub
# Actions secret consumed by .github/workflows/refresh-data.yml. Add it under
# repo Settings → Secrets and variables → Actions, not here.
